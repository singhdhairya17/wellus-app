# Copy this file to `.env.local` and fill in your values (never commit `.env.local`).
# Expo loads `.env.local` when you run `npx expo start`.
# For EAS builds, set the same EXPO_PUBLIC_* names in expo.dev → Environment variables.

# Required — Convex deployment URL (from `npx convex dev` or Convex dashboard)
EXPO_PUBLIC_CONVEX_URL=

# Required — Firebase Web API key (must match apiKey in services/FirebaseConfig.jsx)
EXPO_PUBLIC_FIREBASE_API_KEY=

# Recommended — Expo project ID (notifications / EAS; can match app.json extra.eas.projectId)
EXPO_PUBLIC_EAS_PROJECT_ID=

# Server-side only: add OPENAI_API_KEY in Convex Dashboard → Environment variables (not here).

# Optional — OCR fallbacks
# EXPO_PUBLIC_GOOGLE_VISION_API_KEY=
# EXPO_PUBLIC_AZURE_VISION_API_KEY=
# EXPO_PUBLIC_AZURE_VISION_ENDPOINT=

# Optional — debug OCR logging (1 or true)
# EXPO_PUBLIC_OCR_DEBUG=

# Optional — recipe image API
# EXPO_PUBLIC_AIRGURU_LAB_API_KEY=
